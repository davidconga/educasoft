{
  "name": "educaja-desktop",
  "version": "1.1.0",
  "description": "Educajá — Gestão Escolar (Desktop, offline-first)",
  "main": "main.js",
  "author": "Okulandisa",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:all":   "electron-builder --win --linux --x64"
  },
  "build": {
    "appId": "ao.educaja.desktop",
    "productName": "Educajá",
    "copyright": "© Okulandisa",
    "directories": { "output": "dist" },
    "files": ["main.js", "offline.html", "icon.png", "icon.ico"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.ico"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "icon.png",
      "category": "Office",
      "synopsis": "Plataforma de gestão escolar Educajá",
      "artifactName": "Educaja-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Educajá",
      "installerLanguages": ["pt_PT"],
      "artifactName": "Educaja-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Educaja-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
