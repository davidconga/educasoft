{
  "name": "educa-desktop",
  "version": "1.0.0",
  "description": "Educa — Gestão Escolar (Desktop)",
  "main": "main.js",
  "author": "Okulandisa",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.educa.okulandisa",
    "productName": "Educa",
    "directories": { "output": "dist" },
    "files": ["main.js", "offline.html", "icon.png"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "installerLanguages": ["pt_PT"]
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
