APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Domínios centrais (separados por vírgula) — landing, super-admin e signup.
CENTRAL_DOMAIN=educa.okulandisa.com,educaja.ao,www.educaja.ao

# Sufixo usado para novos tenants criados via cadastro/painel super-admin.
# Tenants antigos continuam a funcionar com o domínio originalmente registado.
TENANT_DOMAIN_SUFFIX=educaja.ao

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Vendus AO (https://www.vendus.co.ao/ws/) - credenciais globais para facturas centrais
VENDUS_BASE_URL=https://www.vendus.co.ao/ws/v1.1/
VENDUS_API_KEY=
VENDUS_REGISTER_ID=
VENDUS_SERIE=
VENDUS_MODO=live
VENDUS_TIMEOUT=20
VENDUS_VERIFY_SSL=true

# Pagamento por referência (gateway Multicaixa)
# Driver activo: vazio = gateway genérico (REF_GATEWAY_*); "intelize" = IntelizeGateway
REF_GATEWAY_DRIVER=
REF_GATEWAY_URL=
REF_GATEWAY_API_KEY=
REF_GATEWAY_METHOD=POST
REF_GATEWAY_PAYLOAD_TEMPLATE={"entidade":"{entidade}","valor":{valor},"validade":"{validade}","descricao":"{descricao}","factura_id":{factura_id}}
REF_ENTIDADE=
REF_VALIDADE_DIAS=30
REF_WEBHOOK_SECRET=

# Intelize (https://www.intelize.digital)
INTELIZE_BASE_URL=https://demo.api.intelize.digital/v1
INTELIZE_USERNAME=
INTELIZE_PASSWORD=
INTELIZE_ENTIDADE=
INTELIZE_CRIADOR=
INTELIZE_AUTH_PATH=/auth
INTELIZE_REFERENCES_PATH=/references
INTELIZE_VALIDADE_DIAS=30
INTELIZE_TOKEN_TTL_MIN=50
